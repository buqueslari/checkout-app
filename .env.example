# Banco de dados Postgres (Neon)
DATABASE_URL=

# Segredo pra assinar o JWT de sessão do admin (gere com: openssl rand -base64 32)
AUTH_SECRET=

# Vercel Blob — opcional, só necessário se for fazer upload de logo em vez de colar uma URL
BLOB_READ_WRITE_TOKEN=

# URL pública final do checkout (usada pra montar os links copiáveis no admin)
NEXT_PUBLIC_APP_URL=http://localhost:3000
